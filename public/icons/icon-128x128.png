    <path d="M128 112C140 108 152 112 160 120" stroke="#768870" stroke-width="2" opacity="0.4"/>
    <path d="M128 144C140 140 152 144 160 152" stroke="#768870" stroke-width="2" opacity="0.4"/>
    <path d="M128 80C116 76 104 80 96 88" stroke="#768870" stroke-width="2" opacity="0.4"/>
    <path d="M128 112C116 108 104 112 96 120" stroke="#768870" stroke-width="2" opacity="0.4"/>
    <path d="M128 144C116 140 104 144 96 152" stroke="#768870" stroke-width="2" opacity="0.4"/>
    
